#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${app_dir}"

dnf update -y
dnf install -y docker docker-compose-plugin git make rsync

systemctl enable docker
systemctl start docker

mkdir -p "$${APP_DIR}"
mkdir -p "$${APP_DIR}/local_files/vid-analyser"
mkdir -p "$${APP_DIR}/local_files"

if id ec2-user >/dev/null 2>&1; then
  usermod -aG docker ec2-user || true
fi
