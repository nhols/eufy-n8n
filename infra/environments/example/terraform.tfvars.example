aws_region            = "eu-west-2"
name                  = "argusai-home"
bucket_name           = "argusai-home-example"
config_key            = "config/run_config.json"
video_prefix          = "videos"
video_expiration_days = 30
enable_bookings_read  = false

vpc_id    = "vpc-xxxxxxxx"
subnet_id = "subnet-xxxxxxxx"

instance_type       = "t3.micro"
root_volume_size_gb = 10
ssh_cidr            = "0.0.0.0/0"
key_name            = "your-ssh-key-name"
app_dir             = "/opt/argusai"

tags = {
  Project     = "argusai"
  Environment = "example"
}
